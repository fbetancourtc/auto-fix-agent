{
  // OpenClaw Configuration — Bumblebee (Auto-Fix Agent)
  // Format: JSON5 (comments and trailing commas OK)
  // Deploy to: ~/.openclaw/openclaw.json
  //
  // NOTE: This is a template. The deployed version at ~/.openclaw/openclaw.json
  // may have additional agents (e.g. Itachi/main), telegram accounts, and secrets.
  // Running setup.sh merges this into the deployed config — it does NOT overwrite.

  gateway: {
    mode: "local",
    port: 18789,
    bind: "loopback",
    auth: { mode: "token" },
    reload: { mode: "hybrid" }
  },

  agents: {
    defaults: {
      workspace: "~/.openclaw/workspace",
      model: "anthropic/claude-opus-4-6",
      sandbox: { mode: "non-main" },
      heartbeat: {
        every: "10m",
        target: "telegram"
      },
      blockStreamingBreak: "text_end"
    },
    list: [
      {
        id: "autofix",
        name: "Bumblebee",
        model: "anthropic/claude-opus-4-6",
        skills: ["code-quality"],
        workspace: "~/.openclaw/workspace/auto-fix-agent"
      }
    ]
  },

  channels: {
    telegram: {
      enabled: true,
      accounts: {
        bumblebee: {
          // botToken: "SET_IN_DEPLOYED_CONFIG",
          dmPolicy: "allowlist",
          allowFrom: ["6437545150"],
          groupPolicy: "disabled"
        }
      }
    }
  },

  models: {
    providers: {
      anthropic: {
        baseUrl: "https://api.anthropic.com",
        models: [
          { id: "claude-opus-4-6", name: "Claude Opus 4.6" }
        ]
      }
    }
  },

  tools: {},

  hooks: {
    enabled: true,
    // token: "SET_IN_DEPLOYED_CONFIG",
    mappings: [
      {
        match: { path: "github" },
        action: "agent",
        agentId: "autofix",
        deliver: true
      }
    ]
  },

  bindings: [
    {
      agentId: "autofix",
      match: { channel: "telegram", accountId: "bumblebee" }
    }
  ],

  cron: {
    enabled: true,
    maxConcurrentRuns: 1,
    sessionRetention: "48h",
    runLog: {
      maxBytes: "2mb",
      keepLines: 2000
    }
  },

  session: {
    scope: "per-sender"
  },

  memory: {
    backend: "builtin",
    citations: "auto"
  }
}
