{
  // OpenClaw Configuration — Code Quality Agent
  // Format: JSON5 (comments and trailing commas OK)
  // Deploy to: ~/.openclaw/openclaw.json

  gateway: {
    mode: "local",
    port: 18789,
    bind: "loopback",
    auth: { mode: "token" },
    reload: { mode: "hybrid" }
  },

  agents: {
    defaults: {
      workspace: "~/.openclaw/workspace",
      model: "anthropic/claude-opus-4-6",
      sandbox: { mode: "non-main" },
      heartbeat: {
        every: "10m",
        target: "telegram"
      },
      blockStreamingBreak: "text_end"
    },
    list: [
      {
        id: "code-quality",
        name: "Bumblebee",
        default: true,
        model: "anthropic/claude-opus-4-6",
        skills: ["code-quality"],
        workspace: "~/.openclaw/workspace"
      }
    ]
  },

  channels: {
    telegram: {
      enabled: true,
      dmPolicy: "allowlist",
      allowFrom: ["6437545150"],
      groupPolicy: "disabled"
    }
  },

  models: {
    providers: {
      anthropic: {
        baseUrl: "https://api.anthropic.com",
        models: [
          { id: "claude-opus-4-6", name: "Claude Opus 4.6" }
        ]
      }
    }
  },

  tools: {},

  hooks: {
    enabled: true,
    mappings: [
      {
        match: { path: "github" },
        action: "agent",
        agentId: "code-quality",
        deliver: true
      }
    ]
  },

  cron: {
    enabled: true,
    maxConcurrentRuns: 1,
    sessionRetention: "48h",
    runLog: {
      maxBytes: "2mb",
      keepLines: 2000
    }
  },

  session: {
    scope: "per-sender"
  },

  memory: {
    backend: "builtin",
    citations: "auto"
  }
}
