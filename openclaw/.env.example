# OpenClaw Environment Variables
# Copy to ~/.openclaw/.env and fill in real values
# NEVER commit this file with real credentials

# --- Required ---

# Anthropic API (Claude Max subscription or API key)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Telegram Bot Token (create via @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# GitHub Personal Access Token (scopes: repo, workflow, admin:org)
GITHUB_TOKEN=your-github-pat-here

# --- Optional ---

# Gateway authentication token (auto-generated if empty)
# OPENCLAW_GATEWAY_TOKEN=

# Webhook secret for GitHub webhook verification
# GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# Sentry DSN for error tracking (reuse from existing auto-fix-agent setup)
# SENTRY_DSN=your-sentry-dsn-here
